<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/proxy_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_main"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
            android:textColor="@color/proxy_text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/subtitle_main"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
            android:textColor="@color/proxy_text_secondary" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/status_stopped"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
            android:textColor="@color/proxy_text_primary"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/label_host"
            android:textColor="@color/proxy_text_primary" />

        <EditText
            android:id="@+id/hostInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@color/proxy_input_surface"
            android:hint="127.0.0.1"
            android:inputType="textNoSuggestions"
            android:maxLines="1"
            android:padding="12dp"
            android:textColor="@color/proxy_text_primary"
            android:textColorHint="@color/proxy_text_hint" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_port"
            android:textColor="@color/proxy_text_primary" />

        <EditText
            android:id="@+id/portInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@color/proxy_input_surface"
            android:hint="1080"
            android:inputType="number"
            android:maxLines="1"
            android:padding="12dp"
            android:textColor="@color/proxy_text_primary"
            android:textColorHint="@color/proxy_text_hint" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_dc_ip"
            android:textColor="@color/proxy_text_primary" />

        <EditText
            android:id="@+id/dcIpInput"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="6dp"
            android:background="@color/proxy_input_surface"
            android:gravity="top|start"
            android:hint="2:149.154.167.220"
            android:inputType="textMultiLine|textNoSuggestions"
            android:minLines="6"
            android:padding="12dp"
            android:textColor="@color/proxy_text_primary"
            android:textColorHint="@color/proxy_text_hint" />

        <CheckBox
            android:id="@+id/verboseCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_verbose"
            android:textColor="@color/proxy_text_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/startButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/action_start" />

            <Space
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/stopButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/action_stop" />
        </LinearLayout>

        <Button
            android:id="@+id/instructionsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/action_instructions" />

        <Button
            android:id="@+id/openInTelegramButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/action_open_in_telegram" />

        <Button
            android:id="@+id/logsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/action_logs" />

        <Button
            android:id="@+id/copyLogsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/action_copy_logs" />

        <TextView
            android:id="@+id/footerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/footer_note"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
            android:textColor="@color/proxy_text_secondary" />

    </LinearLayout>

</ScrollView>
